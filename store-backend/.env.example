NODE_ENV=development
PORT=5000

# Supabase PostgreSQL connection string. DATABASE_URL is also accepted as an alias.
# Local development can use the direct connection (port 5432).
# Serverless deployment should normally use the Supabase transaction pooler (port 6543).
SUPABASE_DB_URL=postgresql://postgres:9141558@@3Ss@db.nfomrgwixkxwzryjtqkf.supabase.co:5432/postgres
SUPABASE_SSL=true
DB_POOL_MAX=5
DB_CONNECT_TIMEOUT_MS=15000
DB_IDLE_TIMEOUT_MS=30000

# Use cryptographically random values of at least 32 characters.
JWT_SECRET=replace_with_a_random_access_token_secret_at_least_32_characters
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=replace_with_a_random_refresh_token_secret_at_least_32_characters
REFRESH_TOKEN_EXPIRES=7d

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
TRUST_PROXY=
BODY_LIMIT=5mb
MAX_UPLOAD_MB=5
API_RATE_LIMIT=500
AUTH_RATE_LIMIT=30
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
ALLOW_PUBLIC_REGISTRATION=false

# Required only when running the admin seed/reset scripts.
ADMIN_NAME=System Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_a_strong_password_of_12_or_more_characters

# Optional one-time MongoDB data migration source.
# Do not configure this after migration is complete.
MONGO_URI_LEGACY=

# Optional SMS provider configuration.
HORMUUD_SMS_API_URL=
HORMUUD_SMS_USERNAME=
HORMUUD_SMS_PASSWORD=
HORMUUD_SMS_SENDER_ID=Bulsho
