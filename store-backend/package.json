{
  "name": "store-management-backend",
  "version": "1.0.0",
  "description": "Production Store Management System using Supabase PostgreSQL",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "seed:admin": "node seed/adminSeeder.js",
    "reset:admin": "node seed/resetAdminPassword.js",
    "test": "node --test --test-concurrency=1 tests/*.test.js",
    "check": "node scripts/checkSource.js",
    "db:sync-indexes": "node scripts/syncIndexes.js",
    "db:verify": "node scripts/syncIndexes.js",
    "db:migrate:mongo": "node scripts/migrateMongoToSupabase.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.22.2",
    "express-rate-limit": "^7.3.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "pdfkit": "^0.18.0",
    "pg": "^8.16.3",
    "sanitize-html": "^2.17.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.3",
    "pg-mem": "^3.0.14",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "uuid": "11.1.1"
  }
}
